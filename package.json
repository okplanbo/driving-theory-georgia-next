{
  "name": "driving-theory-app",
  "version": "1.0.0",
  "description": "Georgian B/B1 Driving Theory Exam Preparation App",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "pages:deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-flag=nodejs_compat",
    "preview": "npm run pages:build && npm run pages:dev",
    "db:migrate": "wrangler d1 execute driving-theory-db --file=./migrations/0001_initial.sql",
    "db:migrate:local": "wrangler d1 execute driving-theory-db --local --file=./migrations/0001_initial.sql"
  },
  "keywords": [
    "driving",
    "theory",
    "exam",
    "georgia",
    "next.js",
    "cloudflare"
  ],
  "author": "okbo.dev",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "lucide-react": "^0.577.0",
    "next": "^15.5.2",
    "postcss": "^8.5.8",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260415.1"
  }
}
